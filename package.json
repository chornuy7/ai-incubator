{
  "name": "ai-incubator-mock",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AI Incubator — панель управления Telegram-аккаунтами с реальной MTProto-авторизацией.",
  "scripts": {
    "dev": "concurrently -n web,api -c blue,green \"vite\" \"node server/index.js\"",
    "dev:web": "vite",
    "dev:api": "node server/index.js",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "test": "node --test server/__tests__/parser.test.js server/__tests__/aiHelp.test.js server/__tests__/accountStatus.test.js server/__tests__/auditLog.test.js"
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "telegram": "^2.26.22",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
